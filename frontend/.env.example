# ── Backend API ────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_INGESTION_API_BASE_URL=http://localhost:8081

# ── Mock Data (dev only) ──────────────────────────────────────
