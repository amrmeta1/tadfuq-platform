# ── Keycloak OIDC ──────────────────────────────────────────────
KEYCLOAK_ISSUER=http://localhost:8180/realms/cashflow
KEYCLOAK_CLIENT_ID=cashflow-api
KEYCLOAK_CLIENT_SECRET=cashflow-api-secret

# ── NextAuth ───────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string

# ── Backend API ────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_INGESTION_API_BASE_URL=http://localhost:8081

# ── Mock Data (dev only) ──────────────────────────────────────
NEXT_PUBLIC_ENABLE_MOCKS=true
