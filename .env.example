# ──────────────────────────────────────────────
# CashFlow.ai – Environment Configuration
# Copy to .env and adjust values for your setup
# ──────────────────────────────────────────────

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=cashflow
DB_PASSWORD=cashflow
DB_NAME=cashflow
DB_SSLMODE=disable

# Auth – Keycloak OIDC (RS256 / JWKS)
AUTH_ISSUER_URL=http://localhost:8180/realms/cashflow
AUTH_JWKS_URL=http://localhost:8180/realms/cashflow/protocol/openid-connect/certs
AUTH_AUDIENCE=cashflow-api
AUTH_JWKS_CACHE_TTL=300

# NATS JetStream (tenant-service)
NATS_URL=nats://localhost:4222
NATS_MAX_RECONNECTS=10
NATS_RECONNECT_WAIT=2
NATS_MAX_ACK_PENDING=256
NATS_MAX_DELIVER=5
NATS_ACK_WAIT=30

# RabbitMQ (ingestion-service)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_RECONNECT_DELAY=5
RABBITMQ_PUBLISH_RETRIES=3
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_RETRY_TTL_5S=5000
RABBITMQ_RETRY_TTL_30S=30000

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=cashflow-tenant-service
